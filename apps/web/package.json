{
  "name": "web",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vite dev --port=4000",
    "prebuild": "bun run scripts/generate-og-paths.ts && bun run scripts/fetch-version.ts",
    "build": "vite build && bun run scripts/generate-og-images.ts",
    "start": "serve .output/public --config ../../serve.json",
    "preview": "vite preview",
    "types:check": "fumadocs-mdx && tsc --noEmit",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@orama/orama": "^3.1.18",
    "@streamdown/code": "^1.0.3",
    "@takumi-rs/image-response": "^0.73.1",
    "@tanstack/react-router": "1.163.2",
    "@tanstack/react-router-devtools": "1.163.2",
    "@tanstack/react-start": "1.163.2",
    "@tanstack/start-static-server-functions": "1.163.2",
    "animejs": "^4.3.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fumadocs-core": "16.6.7",
    "fumadocs-mdx": "14.2.8",
    "fumadocs-ui": "npm:@fumadocs/base-ui@16.6.7",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^3.8.5",
    "streamdown": "^2.3.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "nitro": "^3.0.1-alpha.2",
    "serve": "^14.2.5",
    "srvx": "^0.11.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
